{
  "name": "@deepseek-router/core",
  "version": "1.0.12",
  "description": "Production-grade multi-provider proxy for Claude Code — DeepSeek, Kimi, Qwen, Zhipu with circuit breaker and automatic failover",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cgagm/deepseek-router.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Cgagm/deepseek-router#readme",
  "keywords": ["deepseek", "claude", "ai-router", "failover", "circuit-breaker", "anthropic", "openai", "proxy", "llm", "typescript"],
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^1.6.0"
  }
}
