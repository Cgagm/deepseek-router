{
  "name": "@deepseek-router/core",
  "version": "1.0.0",
  "description": "Production-grade proxy core — circuit breaker, failover, format translation, observability",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "pino-pretty": "^11.0.0",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
